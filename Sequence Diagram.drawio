<mxfile host="app.diagrams.net">
  <diagram name="Page-1" id="KvKzfkJP3eAgm3BH0l3b">
    <mxGraphModel dx="2575" dy="1318" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="850" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml\n\nskinparam sequenceArrowThickness 2\nskinparam roundcorner 10\n\nactor Patient\nactor Doctor\nactor Admin\n\nparticipant \&quot;React Frontend\&quot; as FE\nparticipant \&quot;ASP.NET Core API\&quot; as API\nparticipant \&quot;Identity + JWT\&quot; as AUTH\nparticipant \&quot;SignalR Hub\&quot; as SR\nparticipant \&quot;FastAPI AI Service\&quot; as AI\ndatabase \&quot;SQL Server\&quot; as DB\ndatabase \&quot;Azure Blob Storage\&quot; as BLOB\n\n== 1. Registration &amp; OTP Verification ==\n\nPatient -&gt; FE : Fill Sign Up Form\nactivate FE\nFE -&gt; API : POST /api/auth/register\nactivate API\nAPI -&gt; AUTH : Create User + Hash Password\nactivate AUTH\nAUTH -&gt; DB : INSERT User Record\nDB --&gt; AUTH : OK\nAUTH --&gt; API : User Created\ndeactivate AUTH\nAPI -&gt; Patient : Send OTP to Email\nAPI --&gt; FE : 200 - Redirect to OTP Page\ndeactivate API\n\nPatient -&gt; FE : Enter 6-digit OTP\nFE -&gt; API : POST /api/auth/verify-otp\nactivate API\nAPI -&gt; DB : Validate OTP + Expiry\nDB --&gt; API : Valid\nAPI -&gt; DB : Mark Email Verified\nAPI --&gt; FE : 200 - Account Activated\ndeactivate API\nFE --&gt; Patient : Redirect to Profile Setup\ndeactivate FE\n\n== 2. Login &amp; JWT Token ==\n\nPatient -&gt; FE : Enter Email + Password\nactivate FE\nFE -&gt; API : POST /api/auth/login\nactivate API\nAPI -&gt; AUTH : Validate Credentials\nactivate AUTH\nAUTH -&gt; DB : Query User by Email\nDB --&gt; AUTH : User Record\nAUTH --&gt; API : Credentials Valid + Role\ndeactivate AUTH\nAPI -&gt; AUTH : Generate JWT Token\nAUTH --&gt; API : Signed JWT Token\nAPI --&gt; FE : 200 - token + userInfo\ndeactivate API\nFE -&gt; FE : Store JWT in localStorage\nFE --&gt; Patient : Redirect to Dashboard\ndeactivate FE\n\n== 3. Patient Books Appointment ==\n\nPatient -&gt; FE : Browse Doctors\nactivate FE\nFE -&gt; API : GET /api/doctors\nactivate API\nAPI -&gt; DB : Query Doctors\nDB --&gt; API : Doctors List\nAPI --&gt; FE : 200 - Doctors[]\ndeactivate API\n\nPatient -&gt; FE : Select Doctor + Time Slot\nFE -&gt; API : POST /api/appointments\nactivate API\nAPI -&gt; DB : Check Doctor Availability\nDB --&gt; API : Slot Available\nAPI -&gt; DB : INSERT Appointment\nDB --&gt; API : Created\nAPI -&gt; SR : Notify Doctor\nactivate SR\nSR -&gt; Doctor : New Appointment Request\ndeactivate SR\nAPI --&gt; FE : 201 - Confirmed\ndeactivate API\nFE --&gt; Patient : Show Confirmation\ndeactivate FE\n\n== 4. MRI Upload &amp; AI Analysis ==\n\nPatient -&gt; FE : Upload MRI Image\nactivate FE\nFE -&gt; API : POST /api/ai/analyze\nactivate API\nAPI -&gt; BLOB : Store MRI Image\nBLOB --&gt; API : Image URL\nAPI -&gt; AI : POST /predict\nactivate AI\nAI -&gt; AI : Preprocess Image\nAI -&gt; AI : CNN Forward Pass\nAI -&gt; AI : Generate Grad-CAM Heatmap\nAI --&gt; API : prediction + confidence + heatmap\ndeactivate AI\nAPI -&gt; DB : INSERT Prediction Record\nDB --&gt; API : Saved\nAPI -&gt; SR : Notify Patient\nactivate SR\nSR -&gt; Patient : Analysis Ready\ndeactivate SR\nAPI --&gt; FE : 200 - result\ndeactivate API\nFE --&gt; Patient : Display Result + Heatmap\ndeactivate FE\n\n== 5. Real-time Chat ==\n\nPatient -&gt; FE : Open Chat\nactivate FE\nFE -&gt; SR : Connect WebSocket\nactivate SR\nSR --&gt; FE : Connection Established\n\nPatient -&gt; FE : Send Message\nFE -&gt; SR : SendMessage to Doctor\nSR -&gt; DB : INSERT ChatMessage\nDB --&gt; SR : Saved\nSR -&gt; Doctor : Deliver Message\n\nDoctor -&gt; FE : Send Reply\nactivate FE #lightgreen\nFE -&gt; SR : SendMessage to Patient\nSR -&gt; DB : INSERT Reply\nSR -&gt; Patient : Deliver Reply\ndeactivate FE\ndeactivate SR\ndeactivate FE\n\n== 6. Doctor Reviews AI Result ==\n\nDoctor -&gt; FE : Open Patient History\nactivate FE\nFE -&gt; API : GET /api/patients/{id}/predictions\nactivate API\nAPI -&gt; DB : Query Predictions\nDB --&gt; API : Predictions[]\nAPI --&gt; FE : 200 - Results\ndeactivate API\nFE --&gt; Doctor : Show MRI + Heatmap\n\nDoctor -&gt; FE : Add Professional Notes\nFE -&gt; API : PATCH /api/predictions/{id}/notes\nactivate API\nAPI -&gt; DB : UPDATE Prediction\nDB --&gt; API : Updated\nAPI -&gt; SR : Notify Patient\nactivate SR\nSR -&gt; Patient : Doctor Added Notes\ndeactivate SR\nAPI --&gt; FE : 200 OK\ndeactivate API\nFE --&gt; Doctor : Notes Saved\ndeactivate FE\n\n== 7. Admin Analytics ==\n\nAdmin -&gt; FE : Access Admin Dashboard\nactivate FE\nFE -&gt; API : GET /api/stats/overview\nactivate API\nAPI -&gt; DB : Aggregate Stats\nDB --&gt; API : Stats Data\nAPI --&gt; FE : 200 - stats\ndeactivate API\nFE --&gt; Admin : Show Charts\n\nAdmin -&gt; FE : Verify Doctor Account\nFE -&gt; API : PATCH /api/doctors/{id}/verify\nactivate API\nAPI -&gt; DB : UPDATE Doctor verified=true\nDB --&gt; API : OK\nAPI -&gt; SR : Notify Doctor\nactivate SR\nSR -&gt; Doctor : Account Approved\ndeactivate SR\nAPI --&gt; FE : 200 OK\ndeactivate API\nFE --&gt; Admin : Doctor Verified\ndeactivate FE\n\n@enduml&quot;,&#xa;  &quot;format&quot;: &quot;svg&quot;&#xa;}" id="wfQllGBDPyhjUZpXsBcG-1">
